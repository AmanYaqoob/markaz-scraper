# Copy this file to .env and fill in your values

# Anthropic API (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your website platform: woocommerce | shopify | custom
WEBSITE_PLATFORM=woocommerce

# WooCommerce (if WEBSITE_PLATFORM=woocommerce)
WC_URL=https://yoursite.com
WC_CONSUMER_KEY=ck_...
WC_CONSUMER_SECRET=cs_...

# Shopify (if WEBSITE_PLATFORM=shopify)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
